{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(bin/bundler-audit 2>&1)",
      "Bash(bin/rails generate:*)",
      "Bash(bin/rails db:migrate)",
      "Bash(bin/rails db:seed)",
      "Bash(bin/rails test:*)",
      "Bash(bin/rails test)",
      "Bash(bin/rails test:system)",
      "Bash(bin/rails test:system *)",
      "Bash(bundle exec:*)",
      "Bash(bundle exec rubocop)",
      "Bash(gh issue:*)",
      "Bash(gh repo:*)",
      "Bash(gh pr:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(gh run:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(npm run herb:format)",
      "Bash(npm run herb:format:check)",
      "Bash(npm run herb:lint)",
      "Skill(playwright-cli)",
      "Bash(bin/rails runner:*)",
      "Bash(docker compose -f .devcontainer/compose.yaml exec playwright:*)",
      "Skill(pr.playwright-walkthrough)"
    ],
    "deny": [
      "Bash(bin/rails db:drop)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/lint.sh"
          }
        ]
      }
    ]
  }
}
