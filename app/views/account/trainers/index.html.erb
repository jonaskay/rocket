<div class="flex items-center justify-between">
  <h1 class="font-bold text-4xl"><%= t(".title") %></h1>
  <%= link_to t(".invite_trainer"), new_account_trainer_path, class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium" %>
</div>

<div class="mt-8">
  <% if @trainers.any? %>
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="border-b border-gray-300">
          <th class="py-3 px-4 font-semibold text-gray-700"><%= t(".table_email") %></th>
          <th class="py-3 px-4 font-semibold text-gray-700"><%= t(".table_status") %></th>
        </tr>
      </thead>
      <tbody>
        <% @trainers.each do |trainer| %>
          <tr class="border-b border-gray-200 hover:bg-gray-50">
            <td class="py-3 px-4"><%= trainer.email_address %></td>
            <td class="py-3 px-4">
              <% if trainer.active? %>
                <span class="inline-flex items-center rounded-full bg-green-50 px-2 py-1 text-xs font-medium text-green-700"><%= t(".status_active") %></span>
              <% elsif trainer.inactive? %>
                <span class="inline-flex items-center rounded-full bg-red-50 px-2 py-1 text-xs font-medium text-red-700"><%= t(".status_inactive") %></span>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-yellow-50 px-2 py-1 text-xs font-medium text-yellow-700"><%= t(".status_pending") %></span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-500"><%= t(".empty") %></p>
  <% end %>
</div>
