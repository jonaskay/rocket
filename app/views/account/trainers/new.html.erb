<h1 class="font-bold text-4xl"><%= t(".title") %></h1>

<%= form_with model: @user, url: account_trainers_path, class: "mt-8 max-w-lg space-y-6" do |form| %>
  <% if @user.errors.any? %>
    <div class="rounded-md bg-red-50 border border-red-200 p-4">
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <div>
      <%= form.label :first_name, t(".first_name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :first_name, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :last_name, t(".last_name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :last_name, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :email_address, t(".email"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.email_field :email_address, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= form.submit t(".submit"), class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium cursor-pointer" %>
    <%= link_to t(".cancel"), account_trainers_path, class: "text-sm text-gray-600 hover:underline" %>
  </div>
<% end %>
