<div class="flex items-center justify-between">
  <h1 class="font-bold text-4xl"><%= @client.name %></h1>
  <div class="flex items-center gap-3">
    <%= link_to "Back to Client Accounts", admin_clients_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
    <%= button_to "Delete Account", admin_client_path(@client), method: :delete,
        data: { turbo_confirm: "Are you sure you want to delete #{@client.name}? This will remove all associated users." },
        class: "rounded-md px-3.5 py-2.5 bg-red-600 hover:bg-red-500 text-white font-medium text-sm" %>
  </div>
</div>

<div class="mt-8">
  <h2 class="text-lg font-semibold text-gray-800 mb-4">Users</h2>
  <% if @users.any? %>
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="border-b border-gray-300">
          <th class="py-3 px-4 font-semibold text-gray-700">Email</th>
          <th class="py-3 px-4 font-semibold text-gray-700">Role</th>
          <th class="py-3 px-4 font-semibold text-gray-700">Joined</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="border-b border-gray-200 hover:bg-gray-50">
            <td class="py-3 px-4"><%= user.email_address %></td>
            <td class="py-3 px-4">
              <% if user.client_admin? %>
                <span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700">Account Admin</span>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600">Trainer</span>
              <% end %>
            </td>
            <td class="py-3 px-4"><%= l(user.created_at, format: :long) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-500">No users for this client account.</p>
  <% end %>
</div>
