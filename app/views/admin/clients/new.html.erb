<h1 class="font-bold text-4xl">New Client Account</h1>

<%= form_with model: [:admin, @client], class: "mt-8 max-w-lg space-y-6" do |form| %>
  <% errors = @client.errors.reject { |e| e.attribute.to_s.start_with?("users.") }.map(&:full_message) +
              @client.users.flat_map { |u| u.errors.full_messages } %>
  <% if errors.any? %>
    <div class="rounded-md bg-red-50 border border-red-200 p-4">
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% errors.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <h2 class="text-lg font-semibold text-gray-800 mb-4">Account Details</h2>
    <div>
      <%= form.label :name, "Client Account Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
    </div>
  </div>

  <div>
    <h2 class="text-lg font-semibold text-gray-800 mb-4">Initial Account Admin</h2>
    <%= form.fields_for :users do |user_form| %>
      <div class="space-y-4">
        <div>
          <%= user_form.label :first_name, "First Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= user_form.text_field :first_name, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
        </div>
        <div>
          <%= user_form.label :last_name, "Last Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= user_form.text_field :last_name, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
        </div>
        <div>
          <%= user_form.label :email_address, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= user_form.email_field :email_address, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
        </div>
        <div>
          <%= user_form.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= user_form.password_field :password, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
        </div>
        <div>
          <%= user_form.label :password_confirmation, "Password Confirmation", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= user_form.password_field :password_confirmation, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="flex items-center gap-4">
    <%= form.submit "Create Client Account", class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium cursor-pointer" %>
    <%= link_to "Cancel", admin_clients_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
