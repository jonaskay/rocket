#!/bin/bash
set -e

SUBMIT_PR=false

while [[ "$1" == --* ]]; do
  case "$1" in
    --pr) SUBMIT_PR=true; shift ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

if ! gh auth status &>/dev/null; then
  echo "GitHub CLI is not authenticated. Run \`gh auth login\` to authenticate."
  exit 1
fi

ISSUE=$1
MAX_ITERATIONS=${2:-3}

if [ -z "$ISSUE" ]; then
  echo "Usage: bin/autofix [--pr] <issue_number> [max_review_iterations]"
  exit 1
fi

CLAUDE="claude --dangerously-skip-permissions -p"

echo "=== Picking issue #$ISSUE ==="
session_id=$($CLAUDE "/dev.pick $ISSUE" --output-format json | jq -r '.session_id')

if [ -f "docs/issues/$ISSUE/human_todos.md" ]; then
  echo "Human todos found — complete them manually, then run /dev.commit-todos and /dev.fix"
  exit 1
fi

echo "=== Implementing fix ==="
$CLAUDE "/dev.fix" --resume "$session_id"

bin/review-fix-loop "$ISSUE" "$MAX_ITERATIONS"

if [ "$SUBMIT_PR" = true ]; then
  echo "=== Submitting pull request ==="
  session_id=$($CLAUDE "/pr.walkthrough $ISSUE" --output-format json | jq -r '.session_id')
  $CLAUDE "/pr.submit $ISSUE" --resume "$session_id"
fi
