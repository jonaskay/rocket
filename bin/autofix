#!/bin/bash
set -e

SUBMIT_PR=false

while [[ "$1" == --* ]]; do
  case "$1" in
    --pr) SUBMIT_PR=true; shift ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

ISSUE=$1
MAX_ITERATIONS=${2:-3}

if [ -z "$ISSUE" ]; then
  echo "Usage: bin/autofix [--pr] <issue_number> [max_review_iterations]"
  exit 1
fi

CLAUDE="claude --dangerously-skip-permissions -p"

echo "=== Picking issue #$ISSUE ==="
session_id=$($CLAUDE "/pick-issue $ISSUE" --output-format json | jq -r '.session_id')

if [ -f "docs/issues/$ISSUE/human_todos.md" ]; then
  echo "Human todos found — complete them manually, then run /commit-human-todos and /fix-issue"
  exit 1
fi

echo "=== Implementing fix ==="
$CLAUDE "/fix-issue" --resume "$session_id"

bin/review-fix-loop "$ISSUE" "$MAX_ITERATIONS"

if [ "$SUBMIT_PR" = true ]; then
  echo "=== Submitting pull request ==="
  $CLAUDE "/submit-pr $ISSUE"
fi
